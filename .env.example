# Controls the lead-capture gate.
#   false                -> gate disabled: the whole app is accessible, no wall, no locks.
#                           Use this in local dev (.env.local) to work without gating yourself.
#   true (or unset)      -> gate active (default). Stage 1 is free, stages 2-9 require the form.
#
# In production (Vercel), leave it unset or set it to true.
NEXT_PUBLIC_GATE_ENABLED=true
